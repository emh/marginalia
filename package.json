{
  "name": "marginalia",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,metadata,article -c auto \"npm:dev:web\" \"npm:dev:worker:metadata\" \"npm:dev:worker:article\"",
    "dev:web": "wds --root-dir app --watch --app-index index.html --hostname 127.0.0.1 --port 8010",
    "dev:worker:article": "WRANGLER_LOG_PATH=../../.wrangler/logs wrangler dev --cwd workers/article --config wrangler.toml --ip 127.0.0.1 --port 8787 --inspector-ip 127.0.0.1 --inspector-port 9230 --persist-to ../../.wrangler/state/article",
    "dev:worker:metadata": "WRANGLER_LOG_PATH=../../.wrangler/logs wrangler dev --cwd workers/metadata --config wrangler.toml --ip 127.0.0.1 --port 8788 --inspector-ip 127.0.0.1 --inspector-port 9231 --persist-to ../../.wrangler/state/metadata",
    "check": "node --check app/main.js && node --check app/api.js && node --check app/storage.js && node --check workers/article/src/index.js && node --check workers/metadata/src/index.js"
  },
  "devDependencies": {
    "@web/dev-server": "^0.4.6",
    "concurrently": "^9.2.1",
    "wrangler": "^4.68.0"
  }
}
